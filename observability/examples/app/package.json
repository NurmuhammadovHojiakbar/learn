{
  "name": "observability-demo",
  "version": "1.0.0",
  "description": "Instrumented Express app (metrics + logs + traces) for the Observability course",
  "type": "module",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "start:traced": "node --import ./tracing.js app.js"
  },
  "dependencies": {
    "@opentelemetry/auto-instrumentations-node": "^0.52.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.55.0",
    "@opentelemetry/sdk-node": "^0.55.0",
    "express": "^4.19.2",
    "pino": "^9.5.0",
    "prom-client": "^15.1.3",
    "redis": "^4.7.0"
  }
}
