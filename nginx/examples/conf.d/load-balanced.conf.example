# OPTIONAL: load-balancing variant (Lesson 05).
# Rename to load-balanced.conf (and remove default.conf) to use it, after scaling the app:
#   docker compose up -d --scale api=3
# With Compose's built-in DNS, the single service name already round-robins across
# replicas; this file shows the explicit upstream form with tuning options.

upstream api_pool {
    least_conn;                     # send to the least-busy backend
    server api:3000 max_fails=3 fail_timeout=30s;
    keepalive 32;
}

server {
    listen 80;
    server_name _;

    location / {
        proxy_pass http://api_pool;
        proxy_http_version 1.1;
        proxy_set_header Connection        "";
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
